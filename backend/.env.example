APP_NAME=doananentang-backend
APP_ENV=development
FRONTEND_BASE_URL=http://localhost:3000
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8081,http://127.0.0.1:8081,http://localhost:19006,http://127.0.0.1:19006
POSTGRES_DB=doananentang
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/doananentang
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=15

WEB_REFRESH_COOKIE_NAME=refresh_token
WEB_REFRESH_COOKIE_SECURE=false
WEB_REFRESH_COOKIE_SAMESITE=lax
WEB_REFRESH_COOKIE_DOMAIN=
WEB_REFRESH_COOKIE_PATH=/

PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=admin
PGADMIN_PORT=5050

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=false
SMTP_USE_STARTTLS=true
